// ========================================
// Capabilities (4)
// ========================================

model AgentCapabilityToken {
  id                 String                 @id @default(cuid())
  tokenHash          String                 @unique
  agentId            String
  grantedByUserId    String
  grantedByAgentId   String?
  allowedTools       String[]
  allowedCategories  String[]
  deniedTools        String[]
  workspaceIds       String[]
  maxTokenBudget     Int                    @default(100000)
  usedTokenBudget    Int                    @default(0)
  maxApiCalls        Int                    @default(1000)
  usedApiCalls       Int                    @default(0)
  parentTokenId      String?
  delegationDepth    Int                    @default(0)
  maxDelegationDepth Int                    @default(2)
  revisionVersion    Int                    @default(1)
  status             CapabilityTokenStatus  @default(ACTIVE)
  expiresAt          DateTime?
  revokedAt          DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  agent              ClaudeCodeAgent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  grantedByUser      User                   @relation("GrantedTokens", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  parentToken        AgentCapabilityToken?  @relation("TokenDelegation", fields: [parentTokenId], references: [id])
  childTokens        AgentCapabilityToken[] @relation("TokenDelegation")
  permissionRequests PermissionRequest[]    @relation("GrantedByToken")
  auditLogs          AgentAuditLog[]

  @@index([agentId])
  @@index([grantedByUserId])
  @@index([parentTokenId])
  @@index([status])
  @@map("agent_capability_tokens")
}

model AgentAuditLog {
  id                String                @id @default(cuid())
  agentId           String
  userId            String
  workspaceId       String?
  action            String
  actionType        String
  capabilityTokenId String?
  input             Json?
  output            Json?
  durationMs        Int                   @default(0)
  isError           Boolean               @default(false)
  error             String?
  delegationChain   String[]
  delegationDepth   Int                   @default(0)
  tokensConsumed    Int                   @default(0)
  budgetRemaining   Int                   @default(0)
  createdAt         DateTime              @default(now())
  agent             ClaudeCodeAgent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  capabilityToken   AgentCapabilityToken? @relation(fields: [capabilityTokenId], references: [id])

  @@index([agentId, createdAt])
  @@index([userId, createdAt])
  @@index([capabilityTokenId])
  @@index([action])
  @@index([actionType, createdAt])
  @@map("agent_audit_logs")
}

model ToolInvocation {
  id                 String           @id @default(cuid())
  userId             String
  sessionId          String?
  tool               String
  input              Json
  output             Json?
  durationMs         Int
  tokensConsumed     Int              @default(0)
  error              String?
  isError            Boolean          @default(false)
  parentInvocationId String?
  createdAt          DateTime         @default(now())
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent             ToolInvocation?  @relation("InvocationTree", fields: [parentInvocationId], references: [id])
  children           ToolInvocation[] @relation("InvocationTree")

  @@index([userId, createdAt])
  @@index([tool, createdAt])
  @@index([sessionId])
  @@index([parentInvocationId])
  @@map("tool_invocations")
}

model PermissionRequest {
  id               String                  @id @default(cuid())
  agentId          String
  userId           String
  requestType      String
  requestPayload   Json
  status           PermissionRequestStatus @default(PENDING)
  fallbackBehavior FallbackBehavior        @default(QUEUE)
  grantedTokenId   String?
  denialReason     String?
  expiresAt        DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  agent            ClaudeCodeAgent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedToken     AgentCapabilityToken?   @relation("GrantedByToken", fields: [grantedTokenId], references: [id])

  @@index([agentId])
  @@index([userId, status])
  @@index([status])
  @@map("permission_requests")
}

