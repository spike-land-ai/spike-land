  DRAFTING
  BUILDING
  FINE_TUNING
  TEST
  LIVE
  ARCHIVED
  FAILED
}

enum AppMessageRole {
  USER
  AGENT
  SYSTEM
}

enum EnhancementTier {
  FREE
  TIER_1K
  TIER_2K
  TIER_4K
}

enum EnhancementType {
  STANDARD
  BLEND
  PIPELINE
  AUTO_CROP
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PipelineStage {
  ANALYZING
  CROPPING
  PROMPTING
  GENERATING
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  TRIALING
