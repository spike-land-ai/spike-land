  updatedAt          DateTime   @updatedAt
}

model SandboxJob {
  id          String           @id @default(cuid())
  appId       String
  messageId   String           @unique
  sandboxId   String?
  requestId   String?
  status      SandboxJobStatus @default(PENDING)
  result      Json?
  error       String?
