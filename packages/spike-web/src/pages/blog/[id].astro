---
import { getCollection, render } from 'astro:content';
import fs from 'node:fs/promises';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Analytics from '../../components/Analytics.astro';
import CookieConsent from '../../components/CookieConsent.astro';
import Whisper from '../../components/typography/Whisper.astro';
import Crescendo from '../../components/typography/Crescendo.astro';
import ScrollWeight from '../../components/typography/ScrollWeight.astro';
import GlitchText from '../../components/typography/GlitchText.astro';

// Auto-imported MDX Components
import PersonaBlogViewer from '../../components/mdx/PersonaBlogViewer';
import AgentCoordinationDemo from '../../components/mdx/AgentCoordinationDemo.astro';
import AgentLoopDemo from '../../components/mdx/AgentLoopDemo.astro';
import AttentionSpotlightDemo from '../../components/mdx/AttentionSpotlightDemo.astro';
import AudioPlayer from '../../components/mdx/AudioPlayer.astro';
import BayesianConfidenceDemo from '../../components/mdx/BayesianConfidenceDemo.astro';
import BlogPoll from '../../components/mdx/BlogPoll.astro';
import CacheAwareBuildGraphDemo from '../../components/mdx/CacheAwareBuildGraphDemo.astro';
import Callout from '../../components/mdx/Callout.astro';
import CodeCategorizerQuiz from '../../components/mdx/CodeCategorizerQuiz.astro';
import ContextWindowDesignDemo from '../../components/mdx/ContextWindowDesignDemo.astro';
import ConvergenceDemo from '../../components/mdx/ConvergenceDemo.astro';
import CTAButton from '../../components/mdx/CTAButton.astro';
import DarwinianTreeDemo from '../../components/mdx/DarwinianTreeDemo.astro';
import DependencyCascadeDemo from '../../components/mdx/DependencyCascadeDemo.astro';
import FiveLayerStackDemo from '../../components/mdx/FiveLayerStackDemo.astro';
import FocusedContextDemo from '../../components/mdx/FocusedContextDemo.astro';
import HourglassModelDemo from '../../components/mdx/HourglassModelDemo.astro';
import LiveCategorizer from '../../components/mdx/LiveCategorizer.astro';
import MCPFlowDiagram from '../../components/mdx/MCPFlowDiagram.astro';
import ModelCascadeDemo from '../../components/mdx/ModelCascadeDemo.astro';
import MonolithAntiPatternDemo from '../../components/mdx/MonolithAntiPatternDemo.astro';
import MultiStageBuildDemo from '../../components/mdx/MultiStageBuildDemo.astro';
import ParadigmGuiltTimeline from '../../components/mdx/ParadigmGuiltTimeline.astro';
import PersonaLandingPreview from '../../components/mdx/PersonaLandingPreview.astro';
import PersonalizedSupportBox from '../../components/mdx/PersonalizedSupportBox.astro';
import PersonaSwitcher from '../../components/mdx/PersonaSwitcher.astro';
import PerspectiveCarousel from '../../components/mdx/PerspectiveCarousel.astro';
import PollAnalyticsDashboard from '../../components/mdx/PollAnalyticsDashboard.astro';
import PracticalRulesDemo from '../../components/mdx/PracticalRulesDemo.astro';
import PrefixInvalidationDemo from '../../components/mdx/PrefixInvalidationDemo.astro';
import PyramidReshapeDemo from '../../components/mdx/PyramidReshapeDemo.astro';
import RecursiveZoomDemo from '../../components/mdx/RecursiveZoomDemo.astro';
import RentStoryToggle from '../../components/mdx/RentStoryToggle.astro';
import ScrollStoryCard from '../../components/mdx/ScrollStoryCard.astro';
import SharedOptimizationProblemDemo from '../../components/mdx/SharedOptimizationProblemDemo.astro';
import SpikeChatEmbed from '../../components/mdx/SpikeChatEmbed.astro';
import SpikeCliDemo from '../../components/mdx/SpikeCliDemo.astro';
import SplitScreenDemo from '../../components/mdx/SplitScreenDemo.astro';
import StackCollapseDemo from '../../components/mdx/StackCollapseDemo.astro';
import TestCodeNameVenn from '../../components/mdx/TestCodeNameVenn.astro';
import Tldr from '../../components/mdx/Tldr.astro';
import ToolCount from '../../components/mdx/ToolCount.astro';
import ToolsByCategoryGrid from '../../components/mdx/ToolsByCategoryGrid.astro';

const MDX_COMPONENTS = {
    whisper: Whisper,
    crescendo: Crescendo,
    scrollweight: ScrollWeight,
    glitchtext: GlitchText,
    AgentCoordinationDemo,
    AgentLoopDemo,
    AttentionSpotlightDemo,
    AudioPlayer,
    BayesianConfidenceDemo,
    BlogPoll,
    CacheAwareBuildGraphDemo,
    Callout,
    CodeCategorizerQuiz,
    ContextWindowDesignDemo,
    ConvergenceDemo,
    CTAButton,
    DarwinianTreeDemo,
    DependencyCascadeDemo,
    FiveLayerStackDemo,
    FocusedContextDemo,
    HourglassModelDemo,
    LiveCategorizer,
    MCPFlowDiagram,
    ModelCascadeDemo,
    MonolithAntiPatternDemo,
    MultiStageBuildDemo,
    ParadigmGuiltTimeline,
    PersonaLandingPreview,
    PersonalizedSupportBox,
    PersonaSwitcher,
    PerspectiveCarousel,
    PollAnalyticsDashboard,
    PracticalRulesDemo,
    PrefixInvalidationDemo,
    PyramidReshapeDemo,
    RecursiveZoomDemo,
    RentStoryToggle,
    ScrollStoryCard,
    SharedOptimizationProblemDemo,
    SpikeChatEmbed,
    SpikeCliDemo,
    SplitScreenDemo,
    StackCollapseDemo,
    TestCodeNameVenn,
    Tldr,
    ToolCount,
    ToolsByCategoryGrid
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Fetch raw MDX text as the PRD
let rawPrd = post.body || '';
if (!rawPrd) {
  try {
    const filePath = path.resolve(process.cwd(), '../../content/blog', `${post.id}.mdx`);
    const content = await fs.readFile(filePath, 'utf-8');
    const frontmatterRegex = /^---\n([\s\S]*?)\n---\n([\s\S]*)$/;
    const match = content.match(frontmatterRegex);
    rawPrd = match ? match[2].trim() : content;
  } catch(e) {
    // fallback
  }
}

// Fetch generated variants
let variants = {};
try {
  const variantsFile = path.resolve(process.cwd(), '../../content/blog-variants', `${post.id}.json`);
  const variantsData = await fs.readFile(variantsFile, 'utf-8');
  variants = JSON.parse(variantsData);
} catch (e) {
  // Variants might not exist yet during local dev if script wasn't run
}
---

<Layout
  title={`${post.data.title} - spike.land`}
  description={post.data.description ?? 'Read this article on spike.land.'}
  ogImage={post.data.heroImage ?? '/android-chrome-512x512.png'}
  ogType="article"
>
  <Analytics slot="head" />

  <div class="page-shell">
    <Nav activePath="/blog" />

    <main class="post-main">
      <!-- Hero header -->
      <header class="post-header">
        <div class="rubik-container post-header-inner">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            All articles
          </a>

          <div class="post-meta">
            <time datetime={post.data.date.toISOString()} class="post-date">
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {post.data.author && <span class="post-author">· {post.data.author}</span>}
            {post.data.category && <span class="rubik-chip">{post.data.category}</span>}
          </div>

          <h1 class="post-title">{post.data.title}</h1>

          {post.data.description && (
            <p class="post-lede">{post.data.description}</p>
          )}
        </div>
      </header>

      {post.data.heroImage && (
        <div class="rubik-container hero-image-container">
          <div class="hero-image-wrap">
            <img
              src={post.data.heroImage}
              alt={post.data.heroPrompt || post.data.title}
              class="hero-image"
              loading="eager"
            />
          </div>
        </div>
      )}

      <!-- Article content -->
      <div class="rubik-container post-content-container">
        <PersonaBlogViewer 
          client:load 
          rawPrd={rawPrd} 
          variants={variants} 
          slug={post.id} 
        />
        
        {/* Hidden SEO Content */}
        <div class="hidden" aria-hidden="true">
          <article class="prose post-prose prose-p:font-sans prose-headings:font-display prose-headings:font-bold prose-p:leading-loose max-w-none">
            <Content components={MDX_COMPONENTS} />
          </article>
        </div>
      </div>
    </main>

    <Footer />
    <CookieConsent />
  </div>
</Layout>

<style>
  .page-shell {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .post-main { flex: 1; }

  .post-header {
    padding-block: clamp(3rem, 6vw, 5rem);
    border-bottom: 1px solid var(--border-color);
    background: radial-gradient(ellipse 60% 50% at 50% 0%, color-mix(in srgb, var(--primary-color) 6%, transparent), transparent);
  }

  .post-header-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 52rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--muted-fg);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease);
  }

  .back-link:hover { color: var(--fg); }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .post-date, .post-author {
    font-size: 0.875rem;
    color: var(--muted-fg);
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    max-width: 22ch;
  }

  .post-lede {
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.25rem);
    line-height: 1.65;
    color: var(--muted-fg);
    max-width: 56ch;
    margin: 0;
  }

  .hero-image-container {
    padding-block: 2rem;
  }

  .hero-image-wrap {
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-lg);
  }

  .hero-image {
    width: 100%;
    height: auto;
    display: block;
    max-height: 28rem;
    object-fit: cover;
  }

  .post-content-container {
    padding-block: clamp(2rem, 4vw, 3.5rem);
  }

  .post-prose {
    max-width: 68ch;
  }
</style>
