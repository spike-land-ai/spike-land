---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Sign In - spike.land"
  description="Sign in to your spike.land workspace."
  noindex={true}
>
  <div class="login-shell">
    <!-- Background decoration -->
    <div class="login-bg-glow"></div>

    <!-- Card -->
    <div class="login-card glass-card">
      <!-- Brand -->
      <div class="login-brand">
        <div class="brand-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div>
          <div class="brand-name">spike.land</div>
          <div class="brand-tagline">AI App Store</div>
        </div>
      </div>

      <div class="login-divider"></div>

      <!-- Heading -->
      <div class="login-heading">
        <h1 class="login-title">Welcome back</h1>
        <p class="login-subtitle">Sign in to your workspace and agents.</p>
      </div>

      <!-- Error message -->
      <div id="error-message" class="error-banner" hidden>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span id="error-text"></span>
      </div>

      <!-- OAuth buttons -->
      <div class="oauth-buttons">
        <button id="btn-github" class="oauth-btn oauth-btn--github">
          <svg class="oauth-icon" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          Continue with GitHub
        </button>

        <button id="btn-google" class="oauth-btn oauth-btn--google">
          <svg class="oauth-icon" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </button>
      </div>

      <div class="login-footer-link">
        <a href="/" class="back-home">← Back to spike.land</a>
      </div>
    </div>
  </div>

  <script>
    import { authClient } from '../lib/auth';

    async function checkSession() {
      try {
        const session = await authClient.getSession();
        if (session?.data) {
          window.location.href = '/dashboard';
        }
      } catch (e) {
        console.error("Session check failed", e);
      }
    }
    checkSession();

    const errorEl = document.getElementById('error-message');
    const errorText = document.getElementById('error-text');

    const redirectUrl = new URLSearchParams(window.location.search).get('redirect') || '/dashboard';

    async function handleLogin(provider: 'github' | 'google') {
      if (errorEl) errorEl.hidden = true;
      try {
        await authClient.signIn.social({ provider, callbackURL: redirectUrl });
      } catch (err: unknown) {
        if (errorEl && errorText) {
          errorText.textContent = err instanceof Error ? err.message : 'Login failed';
          errorEl.hidden = false;
        }
      }
    }

    document.getElementById('btn-github')?.addEventListener('click', () => handleLogin('github'));
    document.getElementById('btn-google')?.addEventListener('click', () => handleLogin('google'));
  </script>
</Layout>

<style>
  .login-shell {
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background: var(--bg);
    position: relative;
    overflow: hidden;
  }

  .login-bg-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 40rem;
    height: 40rem;
    background: radial-gradient(circle, color-mix(in srgb, var(--primary-color) 15%, transparent) 0%, transparent 60%);
    pointer-events: none;
  }

  .login-card {
    position: relative;
    width: 100%;
    max-width: 26rem;
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Brand */
  .login-brand {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .brand-icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-lg);
    background: var(--primary-color);
    color: var(--primary-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }

  .brand-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.0625rem;
    letter-spacing: -0.025em;
    color: var(--fg);
  }

  .brand-tagline {
    font-size: 0.75rem;
    color: var(--muted-fg);
    font-weight: 500;
    margin-top: 0.125rem;
  }

  .login-divider {
    height: 1px;
    background: var(--border-color);
  }

  /* Heading */
  .login-heading { display: flex; flex-direction: column; gap: 0.375rem; }

  .login-title {
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0;
  }

  .login-subtitle {
    font-size: 0.875rem;
    color: var(--muted-fg);
    margin: 0;
  }

  /* Error */
  .error-banner {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid color-mix(in srgb, var(--destructive) 30%, transparent);
    background: color-mix(in srgb, var(--destructive) 8%, transparent);
    color: var(--destructive);
    font-size: 0.875rem;
    line-height: 1.45;
  }

  .error-banner svg { flex-shrink: 0; margin-top: 0.1rem; }

  /* OAuth buttons */
  .oauth-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .oauth-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-lg);
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    font-family: var(--font-sans);
    transition: opacity var(--duration-fast) var(--ease),
                transform var(--duration-fast) var(--ease);
    letter-spacing: -0.01em;
  }

  .oauth-btn:hover { opacity: 0.88; transform: translateY(-1px); }
  .oauth-btn:active { transform: translateY(0); }

  .oauth-btn--github {
    background: var(--fg);
    color: var(--bg);
  }

  .oauth-btn--google {
    background: var(--card-bg);
    color: var(--fg);
    border: 1px solid var(--border-color);
    box-shadow: var(--shadow-sm);
  }

  .oauth-icon { width: 1.125rem; height: 1.125rem; flex-shrink: 0; }

  /* Footer link */
  .login-footer-link { text-align: center; }

  .back-home {
    font-size: 0.875rem;
    color: var(--muted-fg);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease);
  }

  .back-home:hover { color: var(--fg); }
</style>
