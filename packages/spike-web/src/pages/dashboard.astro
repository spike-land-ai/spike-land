---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/react/ThemeToggle';

const mockApps = [
    { id: 'codespace', name: 'CodeSpace', status: 'Running', type: 'Environment', accent: '#2563eb' },
    { id: 'qa-studio', name: 'QA Studio', status: 'Idle', type: 'Agent Team', accent: '#16a34a' },
    { id: 'ops-dash', name: 'Ops Dashboard', status: 'Running', type: 'Telemetry', accent: '#9333ea' }
];

const quickActions = [
  { label: 'New App', desc: 'Scaffold a new AI application', iconPath: 'M12 5v14M5 12h14', href: '/apps/app-creator' },
  { label: 'Browse Apps', desc: 'Explore the app store', iconPath: 'M4 6h16M4 12h16M4 18h7', href: '/apps' },
  { label: 'View Docs', desc: 'Read the documentation', iconPath: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25', href: '/blog' },
];
---

<Layout
  title="Dashboard - spike.land"
  description="Your spike.land workspace overview."
  noindex={true}
>
  <div class="dash-shell">
    <!-- Sidebar -->
    <aside class="dash-sidebar">
      <div class="sidebar-brand">
        <div class="brand-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <span class="brand-name">spike.land</span>
      </div>

      <nav class="sidebar-nav">
        <a href="/dashboard" class="sidebar-link sidebar-link--active">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Overview
        </a>
        <a href="/apps" class="sidebar-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
          Apps
        </a>
        <a href="/dashboard/agents" class="sidebar-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 014-4h4a4 4 0 014 4v2"/></svg>
          Agents
        </a>
        <a href="/dashboard/settings" class="sidebar-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          Settings
        </a>
      </nav>

      <div class="sidebar-footer">
        <ThemeToggle client:load />
        <div class="user-info">
          <div class="user-avatar" id="user-avatar">?</div>
          <div class="user-details">
            <div class="user-name" id="user-name">Loading…</div>
            <div class="user-email" id="user-email">demo@spike.land</div>
          </div>
        </div>
        <button id="logout-btn" class="logout-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
          Sign Out
        </button>
      </div>
    </aside>

    <!-- Main content -->
    <div class="dash-main">
      <!-- Top bar -->
      <header class="dash-topbar">
        <h1 class="dash-page-title">Overview</h1>
        <a href="/apps/app-creator" class="topbar-cta">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
          New Deployment
        </a>
      </header>

      <div class="dash-content">
        <!-- Metric cards -->
        <div class="metrics-grid">
          <div class="metric-card rubik-panel">
            <div class="metric-icon" style="background: rgba(37,99,235,0.1); color: #2563eb;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 014-4h4a4 4 0 014 4v2"/></svg>
            </div>
            <div>
              <div class="metric-label">Active Agents</div>
              <div class="metric-value">16</div>
            </div>
          </div>
          <div class="metric-card rubik-panel">
            <div class="metric-icon" style="background: rgba(22,163,74,0.1); color: #16a34a;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
            </div>
            <div>
              <div class="metric-label">Running Apps</div>
              <div class="metric-value">2</div>
            </div>
          </div>
          <div class="metric-card rubik-panel">
            <div class="metric-icon" style="background: rgba(147,51,234,0.1); color: #9333ea;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <div>
              <div class="metric-label">Compute Hours</div>
              <div class="metric-value">128</div>
            </div>
          </div>
        </div>

        <!-- Quick actions -->
        <section class="dash-section">
          <h2 class="section-heading">Quick Actions</h2>
          <div class="quick-actions-grid">
            {quickActions.map(action => (
              <a href={action.href} class="quick-action-card rubik-panel">
                <div class="qa-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d={action.iconPath} />
                  </svg>
                </div>
                <div>
                  <div class="qa-label">{action.label}</div>
                  <div class="qa-desc">{action.desc}</div>
                </div>
              </a>
            ))}
          </div>
        </section>

        <!-- Recent deployments -->
        <section class="dash-section">
          <h2 class="section-heading">Recent Deployments</h2>
          <div class="deployments-table rubik-panel" style="padding: 0; overflow: hidden;">
            <table class="dep-table">
              <thead>
                <tr class="dep-head-row">
                  <th>App</th>
                  <th>Type</th>
                  <th>Status</th>
                  <th class="text-right">Action</th>
                </tr>
              </thead>
              <tbody>
                {mockApps.map(app => (
                  <tr class="dep-row">
                    <td class="dep-name">{app.name}</td>
                    <td class="dep-type">{app.type}</td>
                    <td>
                      <span class={`status-pill ${app.status === 'Running' ? 'status-running' : 'status-idle'}`}>
                        <span class="status-dot"></span>
                        {app.status}
                      </span>
                    </td>
                    <td class="dep-action">
                      <a href={`/apps/${app.id}`} class="manage-link">Manage →</a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      </div>
    </div>
  </div>

  <script>
    import { authClient } from '../lib/auth';

    async function checkAuth() {
      try {
        const session = await authClient.getSession();
        if (!session?.data?.user) {
          window.location.href = '/login?redirect=/dashboard';
          return;
        }
        const userEl = document.getElementById('user-email');
        if (userEl && session.data.user.email) {
          userEl.textContent = session.data.user.email;
        }
        const userNameEl = document.getElementById('user-name');
        if (userNameEl && session.data.user.name) {
          userNameEl.textContent = session.data.user.name;
        }
        const avatarEl = document.getElementById('user-avatar');
        if (avatarEl && session.data.user.name) {
          avatarEl.textContent = session.data.user.name.charAt(0).toUpperCase();
        }
      } catch {
        window.location.href = '/login?redirect=/dashboard';
      }
    }

    checkAuth();

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await authClient.signOut();
      window.location.href = '/';
    });
  </script>
</Layout>

<style>
  .dash-shell {
    min-height: 100svh;
    display: flex;
    background: var(--bg);
  }

  /* Sidebar */
  .dash-sidebar {
    width: 15rem;
    flex-shrink: 0;
    border-right: 1px solid var(--border-color);
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    gap: 1.5rem;
    position: sticky;
    top: 0;
    height: 100svh;
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.25rem 0;
  }

  .brand-icon {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-md);
    background: var(--primary-color);
    color: var(--primary-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .brand-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: -0.025em;
    color: var(--fg);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted-fg);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease),
                background var(--duration-fast) var(--ease);
  }

  .sidebar-link:hover {
    color: var(--fg);
    background: var(--muted-bg);
  }

  .sidebar-link--active {
    color: var(--fg);
    background: color-mix(in srgb, var(--primary-color) 10%, transparent);
    font-weight: 600;
  }

  .sidebar-footer {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    min-width: 0;
  }

  .user-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--primary-color) 20%, transparent);
    color: var(--primary-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8125rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .user-details {
    min-width: 0;
    flex: 1;
  }

  .user-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .user-email {
    font-size: 0.75rem;
    color: var(--muted-fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .logout-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted-fg);
    background: transparent;
    border: 1px solid var(--border-color);
    cursor: pointer;
    font-family: var(--font-sans);
    width: 100%;
    transition: color var(--duration-fast) var(--ease),
                background var(--duration-fast) var(--ease);
  }

  .logout-btn:hover {
    color: var(--fg);
    background: var(--muted-bg);
  }

  /* Main */
  .dash-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .dash-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .dash-page-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .topbar-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    background: var(--primary-color);
    color: var(--primary-fg);
    border-radius: var(--radius-lg);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease);
  }

  .topbar-cta:hover { opacity: 0.88; }

  .dash-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Metrics */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 14rem), 1fr));
    gap: 1rem;
  }

  .metric-card {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .metric-icon {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .metric-label {
    font-size: 0.8125rem;
    color: var(--muted-fg);
    font-weight: 500;
  }

  .metric-value {
    font-size: 1.75rem;
    font-weight: 900;
    font-family: var(--font-display);
    letter-spacing: -0.04em;
    font-variation-settings: "wght" 900;
    margin-top: 0.125rem;
  }

  /* Sections */
  .dash-section { display: flex; flex-direction: column; gap: 0.875rem; }

  .section-heading {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0;
  }

  /* Quick actions */
  .quick-actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 16rem), 1fr));
    gap: 0.875rem;
  }

  .quick-action-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--duration-normal) var(--ease),
                border-color var(--duration-normal) var(--ease),
                transform var(--duration-fast) var(--ease);
  }

  .quick-action-card:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--primary-color) 30%, transparent);
  }

  .qa-icon {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    background: var(--muted-bg);
    color: var(--muted-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background var(--duration-fast) var(--ease),
                color var(--duration-fast) var(--ease);
  }

  .quick-action-card:hover .qa-icon {
    background: color-mix(in srgb, var(--primary-color) 12%, transparent);
    color: var(--primary-color);
  }

  .qa-label {
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .qa-desc {
    font-size: 0.8125rem;
    color: var(--muted-fg);
    margin-top: 0.125rem;
  }

  /* Deployments table */
  .dep-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .dep-head-row th {
    padding: 0.75rem 1.25rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.8125rem;
    color: var(--muted-fg);
    background: var(--muted-bg);
    border-bottom: 1px solid var(--border-color);
  }

  .dep-head-row th.text-right { text-align: right; }

  .dep-row td {
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    color: var(--fg);
    vertical-align: middle;
  }

  .dep-row:last-child td { border-bottom: none; }
  .dep-row:hover td { background: var(--muted-bg); }

  .dep-name { font-weight: 600; }
  .dep-type { color: var(--muted-fg); }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
  }

  .status-running {
    background: rgba(22,163,74,0.12);
    color: #16a34a;
    border: 1px solid rgba(22,163,74,0.2);
  }

  .status-idle {
    background: rgba(234,179,8,0.12);
    color: #ca8a04;
    border: 1px solid rgba(234,179,8,0.2);
  }

  .status-dot {
    width: 0.4375rem;
    height: 0.4375rem;
    border-radius: 50%;
    background: currentColor;
  }

  .dep-action { text-align: right; }

  .manage-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--primary-color);
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease);
  }

  .manage-link:hover { opacity: 0.7; }
</style>
