{
  "name": "lucide-react",
  "version": "0.577.0",
  "private": true,
  "description": "Animated SVG icons for spike.land - Drop-in replacement for lucide-react",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "peerDependencies": {
    "framer-motion": "^11.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "real-lucide-react": "npm:lucide-react@^0.300.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "framer-motion": "^11.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
