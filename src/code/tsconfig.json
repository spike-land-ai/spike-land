{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "ESNext", "ESNext.AsyncIterable", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@emotion/react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "dist",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "allowImportingTsExtensions": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./@/*"],
      "shadcn-packaged/*": ["../../node_modules/shadcn-packaged/*"],
      "@spike-land-ai/shared": ["../shared/index.ts"],
      "@spike-land-ai/shared/*": ["../shared/*"],
      "@spike-land-ai/esbuild-wasm": ["../esbuild-wasm/lib/main.d.ts"],
      "@spike-land-ai/esbuild-wasm-mcp": ["../esbuild-wasm-mcp/index.ts"],
      "@spike-land-ai/react-ts-worker": ["../react-ts-worker/react/index.ts"],
      "@spike-land-ai/react-ts-worker/*": ["../react-ts-worker/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["__tests__/**", "**/*.test.ts", "**/*.test.tsx"]
}
