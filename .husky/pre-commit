#!/bin/sh
# Secret detection — warn if gitleaks is missing, fail if it finds secrets
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --pre-commit --staged --verbose
else
  echo "Warning: gitleaks not installed — skipping secret detection"
fi

# Format staged files with Biome
STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx' '*.json')
if [ -n "$STAGED" ]; then
  echo "$STAGED" | xargs npx biome format --write 2>/dev/null
  echo "$STAGED" | xargs git add
fi

# Typecheck staged TS files
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx')
if [ -n "$STAGED_TS" ]; then
  npx tsc --noEmit --incremental
fi
