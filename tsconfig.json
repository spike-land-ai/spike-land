{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "sourceMap": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/code/@/*"],
      "@spike-land-ai/shared": ["./src/shared/index.ts"],
      "@spike-land-ai/shared/*": ["./src/shared/*"],
      "@spike-land-ai/mcp-server-base": ["./src/mcp-server-base/index.ts"],
      "@spike-land-ai/block-sdk": ["./src/block-sdk/index.ts"],
      "@spike-land-ai/block-sdk/storage": ["./src/block-sdk/storage/index.ts"],
      "@spike-land-ai/block-sdk/adapters/d1": ["./src/block-sdk/adapters/d1.ts"],
      "@spike-land-ai/block-sdk/adapters/idb": ["./src/block-sdk/adapters/idb.ts"],
      "@spike-land-ai/block-sdk/react": ["./src/block-sdk/react/index.ts"],
      "@spike-land-ai/block-sdk/mcp": ["./src/block-sdk/mcp/index.ts"],
      "@spike-land-ai/block-tasks": ["./src/block-tasks/index.ts"],
      "@spike-land-ai/esbuild-wasm": ["./packages/esbuild-wasm/lib/main.d.ts"],
      "@spike-land-ai/esbuild-wasm-mcp": ["./src/esbuild-wasm-mcp/index.ts"],
      "@spike-land-ai/react-ts-worker": ["./src/react-ts-worker/react/index.ts"],
      "@spike-land-ai/react-ts-worker/*": ["./src/react-ts-worker/*"],
      "@spike-land-ai/code": ["./src/code/modules.ts"],
      "@spike-land-ai/code/src/@/*": ["./src/code/@/*"],
      "@spike-land-ai/code/*": ["./src/code/*"],
      "@spike-land-ai/spike-cli": ["./src/spike-cli/index.ts"],
      "@spike-land-ai/spike-review": ["./src/spike-review/index.ts"],
      "@spike-land-ai/spike-review/*": ["./src/spike-review/*"],
      "@spike-land-ai/hackernews-mcp": ["./src/hackernews-mcp/index.ts"],
      "@spike-land-ai/mcp-image-studio": ["./src/mcp-image-studio/index.ts"],
      "@spike-land-ai/mcp-image-studio/*": ["./src/mcp-image-studio/*"],
      "@spike-land-ai/openclaw-mcp": ["./src/openclaw-mcp/index.ts"],
      "@spike-land-ai/bazdmeg-mcp": ["./src/bazdmeg-mcp/index.ts"],
      "@spike-land-ai/chess-engine": ["./src/chess-engine/index.ts"],
      "@spike-land-ai/qa-studio": ["./src/qa-studio/index.ts"],
      "@spike-land-ai/state-machine": ["./src/state-machine/index.ts"],
      "@spike-land-ai/state-machine/*": ["./src/state-machine/*"],
      "@spike-land-ai/vibe-dev": ["./src/vibe-dev/cli.ts"],
      "@spike-land-ai/video": ["./src/video/index.ts"],
      "@spike-land-ai/image-studio-worker": ["./src/image-studio-worker/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "packages/*/dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "src/spike-app/**",
    "src/code/**",
    "src/chess-engine/**",
    "src/image-studio-worker/frontend/**",
    "src/state-machine/persistence.ts"
  ]
}
