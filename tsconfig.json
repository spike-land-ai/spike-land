{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "sourceMap": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/frontend/monaco-/*"
      ],
      "@spike-land-ai/shared": [
        "./src/core/shared-utils/ui/index.ts"
      ],
      "@spike-land-ai/shared/*": [
        "./src/core/shared-utils/ui/*"
      ],
      "@spike-land-ai/mcp-server-base": [
        "./src/core/server-base/core-logic/index.ts"
      ],
      "@spike-land-ai/block-sdk": [
        "./src/core/block-sdk/misc/index.ts"
      ],
      "@spike-land-ai/block-sdk/storage": [
        "./src/core/block-sdk/core-logic/storage-index.ts"
      ],
      "@spike-land-ai/block-sdk/adapters/d1": [
        "./src/core/block-sdk/core-logic/d1.ts"
      ],
      "@spike-land-ai/block-sdk/adapters/idb": [
        "./src/core/block-sdk/db/idb.ts"
      ],
      "@spike-land-ai/block-sdk/react": [
        "./src/core/block-sdk/ui/react-index.ts"
      ],
      "@spike-land-ai/block-sdk/mcp": [
        "./src/core/block-sdk/misc/mcp-index.ts"
      ],
      "@spike-land-ai/block-tasks": [
        "./src/core/block-tasks/misc/index.ts"
      ],
      "@spike-land-ai/esbuild-wasm": [
        "./packages/esbuild-wasm/lib/main.d.ts"
      ],
      "@spike-land-ai/esbuild-wasm-mcp": [
        "./src/mcp-tools/esbuild-wasm/mcp/index.ts"
      ],
      "@spike-land-ai/react-ts-worker": [
        "./src/core/react-engine/core-logic/react-index.ts"
      ],
      "@spike-land-ai/react-ts-worker/*": [
        "./src/core/react-engin/*"
      ],
      "@spike-land-ai/code": [
        "./src/frontend/monaco-editor/core-logic/modules.ts"
      ],
      "@spike-land-ai/code/src/@/*": [
        "./src/frontend/monaco-/*"
      ],
      "@spike-land-ai/code/*": [
        "./src/frontend/monaco-editor/animation-ui/*"
      ],
      "@spike-land-ai/spike-cli": [
        "./src/cli/spike-cli/ai/index.ts"
      ],
      "@spike-land-ai/spike-review": [
        "./src/mcp-tools/code-review/mcp/index.ts"
      ],
      "@spike-land-ai/spike-review/*": [
        "./src/mcp-tools/code-review/mcp/*"
      ],
      "@spike-land-ai/hackernews-mcp": [
        "./src/mcp-tools/hackernews/mcp/index.ts"
      ],
      "@spike-land-ai/mcp-image-studio": [
        "./src/mcp-tools/image-studio/mcp/index.ts"
      ],
      "@spike-land-ai/mcp-image-studio/*": [
        "./src/mcp-tools/image-studio/mcp/*"
      ],
      "@spike-land-ai/openclaw-mcp": [
        "./src/mcp-tools/openclaw/core-logic/index.ts"
      ],
      "@spike-land-ai/bazdmeg-mcp": [
        "./src/mcp-tools/bazdmeg/mcp/index.ts"
      ],
      "@spike-land-ai/chess-engine": [
        "./src/core/chess/chess-core/index.ts"
      ],
      "@spike-land-ai/qa-studio": [
        "./src/core/browser-automation/testing-mcp-edge/index.ts"
      ],
      "@spike-land-ai/state-machine": [
        "./src/core/statecharts/node-sys/index.ts"
      ],
      "@spike-land-ai/state-machine/*": [
        "./src/core/statecharts/cli/*"
      ],
      "@spike-land-ai/vibe-dev": [
        "./src/cli/docker-dev/core-logic/cli.ts"
      ],
      "@spike-land-ai/video": [
        "./src/frontend/educational-videos/video/index.ts"
      ],
      "@spike-land-ai/image-studio-worker": [
        "./src/edge-api/image-studio-worker/ai-api-mcp/index.ts"
      ],
      "monaco-editor": [
        "./packages/monaco-editor/src/index.ts"
      ],
      "monaco-editor/*": [
        "./packages/monaco-editor/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "packages/*/dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "src/spike-app/**",
    "src/code/**",
    "src/chess-engine/**",
    "src/image-studio-worker/frontend/**",
    "src/state-machine/persistence.ts"
  ]
}
